{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data, wallet info, and balances.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "suiWallet": { "type": "string" },
        "suiBalance": { "type": "number" },
        "usdtBalance": { "type": "number" },
        "totalProfit": { "type": "number" },
        "activeStrategy": { "type": "string", "enum": ["Aggressive", "Momentum", "Scalping", "Conservative", "None"] },
        "isTrading": { "type": "boolean" },
        "region": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "suiWallet"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post in the community feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "content", "createdAt"]
    },
    "Trade": {
      "title": "Trade Transaction",
      "description": "Record of a trading activity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "pair": { "type": "string" },
        "type": { "type": "string", "enum": ["Buy", "Sell"] },
        "amount": { "type": "number" },
        "price": { "type": "number" },
        "pnl": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "pair", "type", "amount", "price", "timestamp"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "In-app notification for user events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["Transfer", "Trade", "Community"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and account state."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts feed."
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Global trade history for analytics and leaderboard."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications."
    }
  }
}
