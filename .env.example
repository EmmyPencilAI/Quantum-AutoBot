# === REQUIRED FOR RENDER / NON-GOOGLE HOSTING ===
# Paste the ENTIRE contents of your Google credential JSON here.
# Supports both "authorized_user" (from gcloud CLI) and "service_account" (from Firebase Console) types.
GOOGLE_CREDENTIALS_JSON=

# Sui blockchain keys
SUI_PRIVATE_KEY=
VITE_SUI_CONTRACT_ADDRESS=
VITE_SUI_TREASURY_ADDRESS=

# CoinGecko API key (optional, works without it but may be rate-limited)
COINGECKO_API_KEY=

# Application mode
VITE_MODE=demo
VITE_SUI_NETWORK=testnet
