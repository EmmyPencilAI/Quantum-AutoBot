# ─── Backend ──────────────────────────────────────────────────────────────────

# CoinGecko API key for live market data
# Get a free key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Sui treasury private key — used by the server to execute on-chain settlements
# Format: either a hex string (0x...) or a Bech32 suiprivkey string
# ⚠️  CRITICAL: Never commit this. Use a secrets manager in production.
SUI_PRIVATE_KEY=

# Firebase Admin SDK — injected at runtime from firebase-applet-config.json
# In production, set these directly as environment variables instead of using the JSON file:
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_ID=(default)

# Platform admin email — users with this verified email get admin privileges
# Set via custom claims instead for production: node scripts/set-admin.mjs <uid>
ADMIN_EMAIL=

# Comma-separated list of allowed CORS origins for the Express API
# Example: https://myapp.vercel.app,https://myapp.com
ALLOWED_ORIGINS=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────

# Deployed Sui Move contract address (after running `sui client publish`)
VITE_SUI_CONTRACT_ADDRESS=

# Quantum Finance treasury wallet address on Sui
VITE_SUI_TREASURY_ADDRESS=

# Application mode:
#   demo  — bypasses real on-chain interactions, safe for UI testing
#   live  — uses real Sui testnet/mainnet transactions
VITE_MODE=demo

# Sui network to connect to: testnet | mainnet | devnet
VITE_SUI_NETWORK=testnet
