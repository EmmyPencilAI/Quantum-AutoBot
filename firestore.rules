rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "emmanuelobed877@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'content', 'createdAt']) &&
             data.authorUid is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             (data.createdAt is string || data.createdAt is timestamp) &&
             (data.authorName is string || !('authorName' in data)) &&
             (data.authorAvatar is string || !('authorAvatar' in data)) &&
             (data.likesCount is number || !('likesCount' in data)) &&
             (data.commentsCount is number || !('commentsCount' in data));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['uid', 'content', 'createdAt']) &&
             data.uid is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users: Only owner can read/write their own profile.
    // Validation is relaxed to allow the trading engine to update
    // dynamic fields (walletBalance, isTrading, totalProfit, etc.).
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin(); 
      allow create: if isOwner(userId) &&
                       request.resource.data.uid is string &&
                       request.resource.data.displayName is string &&
                       request.resource.data.suiWallet is string;
      allow update: if isOwner(userId);
    }

    // Posts: Anyone can read, only authenticated can create, owner can update/delete.
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.authorUid || isAdmin()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount']) && 
         (math.abs(request.resource.data.likesCount - resource.data.likesCount) == 1 || 
          request.resource.data.commentsCount == resource.data.commentsCount + 1 ||
          math.abs(request.resource.data.commentsCount - resource.data.commentsCount) == 1))
      );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || isAdmin());

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      }

      // Likes subcollection
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Trades: Anyone can read (for leaderboard/activity feed).
    // Authenticated users (trading engine) can create trades.
    // Trade type accepts both 'Buy'/'Sell' and 'BUY'/'SELL' formats.
    match /trades/{tradeId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.uid is string &&
                       request.resource.data.pair is string &&
                       request.resource.data.type is string &&
                       request.resource.data.amount is number &&
                       request.resource.data.price is number &&
                       (request.resource.data.timestamp is string || request.resource.data.timestamp is timestamp);
      allow update: if false; // Trades are immutable records
      allow delete: if false;
    }

    // Notifications: Only owner can read/write their own notifications.
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated(); // System can create notifications for users
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid);
    }

    // Health check (used by server)
    match /health_check/{docId} {
      allow read: if true;
      allow write: if false; // Only Admin SDK writes here
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
