rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid} (Firebase UID)
    // Fields:
    //   - walletAddress: string (required, immutable)
    //   - username: string (required)
    //   - avatar: string (optional)
    //   - totalProfit: number (required)
    //   - strategy: string (optional)
    //   - region: string (optional)
    //   - lastActive: string (required)
    //   - role: string (optional)
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - authorUid: string (required, immutable, Firebase UID)
    //   - authorName: string (required)
    //   - authorAvatar: string (optional)
    //   - authorWallet: string (required)
    //   - content: string (required)
    //   - likes: number (required)
    //   - createdAt: string (required, immutable)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "emmanuelobed877@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['walletAddress', 'username', 'totalProfit', 'lastActive']) &&
             data.walletAddress is string && data.walletAddress.size() > 0 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.totalProfit is number &&
             data.lastActive is string &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'authorName', 'authorWallet', 'content', 'likes', 'createdAt']) &&
             data.authorUid is string && data.authorUid == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 50 &&
             data.authorWallet is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             data.likes is number &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data) && 
                    request.resource.data.walletAddress == resource.data.walletAddress &&
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.authorUid && isValidPost(request.resource.data) && request.resource.data.authorUid == resource.data.authorUid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) && request.resource.data.likes == resource.data.likes + 1)
      );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    match /trades/{tradeId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create: if isAuthenticated() && isValidTrade(request.resource.data);
    }
  }
}
