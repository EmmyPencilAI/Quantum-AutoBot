rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "emmanuelobed877@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'suiWallet']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.suiWallet is string && data.suiWallet.size() > 0 &&
             (data.avatar is string || !('avatar' in data)) &&
             (data.photoURL is string || !('photoURL' in data)) &&
             (data.email is string || !('email' in data)) &&
             (data.suiBalance is number || !('suiBalance' in data)) &&
             (data.usdtBalance is number || !('usdtBalance' in data)) &&
             (data.usdcBalance is number || !('usdcBalance' in data)) &&
             (data.walletBalance is number || !('walletBalance' in data)) &&
             (data.isTrading is bool || !('isTrading' in data)) &&
             (data.initialInvestment is number || !('initialInvestment' in data)) &&
             (data.totalProfit is number || !('totalProfit' in data)) &&
             (data.activeStrategy is string || !('activeStrategy' in data)) &&
             (data.activePair is string || !('activePair' in data)) &&
             (data.tradingAsset is string || !('tradingAsset' in data)) &&
             (data.connectedWallet is string || data.connectedWallet == null || !('connectedWallet' in data)) &&
             (data.tradeCount is number || !('tradeCount' in data)) &&
             (data.tradingStartedAt is string || !('tradingStartedAt' in data)) &&
             (data.currentLotSize is number || !('currentLotSize' in data)) &&
             (data.currentTrend is string || !('currentTrend' in data)) &&
             (data.lastTradeAt is string || !('lastTradeAt' in data)) &&
             (data.tradingSessionId is string || data.tradingSessionId == null || !('tradingSessionId' in data)) &&
             (data.timestamp is string || !('timestamp' in data));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'content', 'createdAt']) &&
             data.authorUid is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             (data.createdAt is string || data.createdAt is timestamp) &&
             (data.authorName is string || !('authorName' in data)) &&
             (data.authorAvatar is string || !('authorAvatar' in data)) &&
             (data.likesCount is number || !('likesCount' in data)) &&
             (data.commentsCount is number || !('commentsCount' in data));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['uid', 'content', 'createdAt']) &&
             data.uid is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['uid', 'pair', 'type', 'amount', 'price', 'timestamp']) &&
             data.uid is string &&
             data.pair is string &&
             data.type in ['Buy', 'Sell'] &&
             data.amount is number && data.amount >= 0 &&
             data.price is number && data.price >= 0 &&
             (data.timestamp is string || data.timestamp is timestamp);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['uid', 'title', 'message', 'createdAt']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users: Only owner can read/write their own profile.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin(); 
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Posts: Anyone can read, only authenticated can create, owner can update/delete.
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.authorUid || isAdmin()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount']) && 
         (math.abs(request.resource.data.likesCount - resource.data.likesCount) == 1 || 
          request.resource.data.commentsCount == resource.data.commentsCount + 1 ||
          math.abs(request.resource.data.commentsCount - resource.data.commentsCount) == 1))
      );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || isAdmin());

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      }

      // Likes subcollection
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Trades: Anyone can read (for leaderboard), only system/owner can create.
    match /trades/{tradeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidTrade(request.resource.data);
      allow update: if false; // Trades are immutable records
      allow delete: if false;
    }

    // Notifications: Only owner can read/write their own notifications.
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated(); // System can create notifications for users
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
