rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'suiWallet']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.suiWallet is string && data.suiWallet.size() > 0 &&
             (data.avatar is string || !('avatar' in data)) &&
             (data.suiBalance is number || !('suiBalance' in data)) &&
             (data.usdtBalance is number || !('usdtBalance' in data));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'content', 'createdAt']) &&
             data.authorUid is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             data.createdAt is string &&
             (data.authorName is string || !('authorName' in data)) &&
             (data.authorAvatar is string || !('authorAvatar' in data)) &&
             (data.likesCount is number || !('likesCount' in data)) &&
             (data.commentsCount is number || !('commentsCount' in data));
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['uid', 'pair', 'type', 'amount', 'price', 'timestamp']) &&
             data.uid is string &&
             data.pair is string &&
             data.type in ['Buy', 'Sell'] &&
             data.amount is number && data.amount >= 0 &&
             data.price is number && data.price >= 0 &&
             data.timestamp is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['uid', 'title', 'message', 'createdAt']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users: Only owner can read/write their own profile.
    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading other profiles for community/leaderboard
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Posts: Anyone can read, only authenticated can create, owner can update/delete.
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.authorUid || request.auth.uid == 'admin') ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) && 
         request.resource.data.likesCount == resource.data.likesCount + 1)
      );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || request.auth.uid == 'admin');
    }

    // Trades: Anyone can read (for leaderboard), only system/owner can create.
    match /trades/{tradeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidTrade(request.resource.data);
      allow update: if false; // Trades are immutable records
      allow delete: if false;
    }

    // Notifications: Only owner can read/write their own notifications.
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated(); // System can create notifications for users
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
