rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // Helper Functions
    // ═══════════════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin role is set via Firebase Admin SDK custom claims.
    // Never use hard-coded emails here — email can change or be compromised.
    // Set admin: firebase-admin auth().setCustomUserClaims(uid, { role: 'admin' })
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Owner check when uid is stored in the document data
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Validated user document shape (minimal required fields)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string &&
             data.displayName.size() > 0 &&
             data.displayName.size() < 100 &&
             // suiWallet can be null (pre-verification) or a string (post-verification)
             (!('suiWallet' in data) || data.suiWallet == null || data.suiWallet is string) &&
             // Prevent users from granting themselves admin via profile write
             !('role' in data);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'content', 'createdAt']) &&
             data.authorUid is string &&
             data.authorUid == request.auth.uid &&  // Can only post as yourself
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 2000 &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['uid', 'content', 'createdAt']) &&
             data.uid is string &&
             data.uid == request.auth.uid &&  // Can only comment as yourself
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 1000;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Users Collection
    // SECURITY: Users can ONLY read and write their OWN profile.
    // Leaderboard data is served exclusively by the backend via Admin SDK
    // (which bypasses these rules). No cross-user profile reads from clients.
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // User deletion handled by Admin SDK only
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Posts Collection
    // Community posts are publicly readable.
    // Users can only create posts with their own uid.
    // ═══════════════════════════════════════════════════════════════════════
    match /posts/{postId} {
      allow read: if true; // Public community feed

      allow create: if isAuthenticated() && isValidPost(request.resource.data);

      allow update: if isAuthenticated() && (
        // Author or admin can do a full edit
        (request.auth.uid == resource.data.authorUid || isAdmin()) ||
        // Any authenticated user can ONLY increment/decrement likesCount or commentsCount
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount']) &&
          (
            math.abs(request.resource.data.likesCount - resource.data.likesCount) == 1 ||
            math.abs(request.resource.data.commentsCount - resource.data.commentsCount) == 1
          )
        )
      );

      allow delete: if isAuthenticated() &&
                    (request.auth.uid == resource.data.authorUid || isAdmin());

      // Comments sub-collection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow update, delete: if isAuthenticated() &&
                               (request.auth.uid == resource.data.uid || isAdmin());
      }

      // Likes sub-collection — each user manages their own like document
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Trades Collection
    // PRIVACY: Trades are ONLY readable by the owning user.
    // The global activity feed is served by the backend Admin SDK.
    // Trades are immutable — no client-side updates or deletes.
    // ═══════════════════════════════════════════════════════════════════════
    match /trades/{tradeId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create: if isAuthenticated() &&
                    request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Trades are immutable once written
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Notifications Collection
    // Users can read, mark-as-read, or delete their own notifications.
    // ONLY the server (Admin SDK) can create notifications.
    // ═══════════════════════════════════════════════════════════════════════
    match /notifications/{notificationId} {
      allow read:   if isDocOwner();
      allow create: if false; // Server-only via Admin SDK (bypasses rules)
      allow update: if isDocOwner() &&
                    // Clients can only toggle the 'read' field
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isDocOwner();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Trade Intents Collection
    // Users can read their own intents.
    // ALL create/update operations are server-only (Admin SDK).
    // ═══════════════════════════════════════════════════════════════════════
    match /trade_intents/{intentId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create, update, delete: if false; // Server-only
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Health Check — Server-only
    // ═══════════════════════════════════════════════════════════════════════
    match /health_check/{docId} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Default Deny All
    // Any collection not explicitly matched above is denied.
    // ═══════════════════════════════════════════════════════════════════════
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
